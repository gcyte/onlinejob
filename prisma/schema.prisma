// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  EMPLOYER
  FREELANCER
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  SHORTLISTED
  HIRED
  REJECTED
  COMPLETED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(FREELANCER)
  isBanned      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  
  freelancerProfile FreelancerProfile?
  employerProfile   EmployerProfile?
  
  // Conversations where the user is a participant
  initiatedConversations Conversation[] @relation("InitiatedBy")
  receivedConversations  Conversation[] @relation("ReceivedBy")
  messages               Message[]
  notifications          Notification[]
  adminLogs              AdminLog[]
  reports                Report[]
  tickets                SupportTicket[]
  ticketMessages         TicketMessage[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum VerificationStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

model FreelancerProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  title          String?
  bio            String?  @db.Text
  skills         String?  @db.Text // JSON string of skills
  expectedSalary Float?
  availability   String?
  resumeUrl      String?
  avatarUrl      String?
  phone          String?
  location       String?
  portfolioUrl   String?
  experience     String?  @db.Text // JSON string of experience
  education      String?  @db.Text // JSON string of education
  socialLinks    String?  @db.Text // JSON string of social links
  trustScore     Int      @default(0)
  isVerified     Boolean  @default(false)
  
  // Verification fields
  idCardUrl          String?
  addressProofUrl    String?
  verificationStatus VerificationStatus @default(NOT_SUBMITTED)
  adminNotes         String? @db.Text
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]
  savedJobs    SavedJob[]
  reviews      Review[]    @relation("FreelancerReviews")
}

model EmployerProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  companyName    String?
  companyWebsite String?
  companyLogo    String?
  coverPhotoUrl  String?
  companyAddress String?
  description    String?  @db.Text
  industry       String?
  companySize    String?
  cultureValues  String?  @db.Text // JSON string array of { id, title, description, icon }
  isPremium      Boolean  @default(false)
  stripeCustomerId String?

  // Verification fields
  idCardUrl          String?
  addressProofUrl    String?
  verificationStatus VerificationStatus @default(NOT_SUBMITTED)
  isVerified         Boolean  @default(false)
  adminNotes         String? @db.Text
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs JobPost[]
  reviews Review[] @relation("EmployerReviews")
}

model JobPost {
  id            String   @id @default(cuid())
  employerId    String
  title         String
  description   String   @db.Text
  requirements  String   @db.Text
  category      String?
  skills        String?  @db.Text // JSON string array
  salaryMin     Float?
  salaryMax     Float?
  salaryCurrency String? @default("USD")
  salaryFrequency String? @default("Monthly")
  experienceLevel String?
  englishProficiency String?
  workStyle     String? @default("Remote")
  salaryRange   String?
  jobType       JobType  @default(FULL_TIME)
  location      String?
  status        String   @default("PENDING") // DRAFT, PENDING, APPROVED, CLOSED, REJECTED
  isPublished   Boolean  @default(true) // @deprecated Use status instead
  isModerated   Boolean  @default(false) // @deprecated Use status instead
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  employer EmployerProfile @relation(fields: [employerId], references: [id], onDelete: Cascade)
  applications Application[]
  savedBy      SavedJob[]
}

model Application {
  id                  String            @id @default(cuid())
  jobId               String
  freelancerProfileId String
  coverLetter         String            @db.Text
  resumeUrl           String?
  attachments         String?           @db.Text // JSON string for multiple attachment URLs
  status              ApplicationStatus @default(PENDING)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  
  job               JobPost           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  freelancerProfile FreelancerProfile @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)
  review            Review?
}

model SavedJob {
  id                  String            @id @default(cuid())
  jobId               String
  freelancerProfileId String
  createdAt           DateTime          @default(now())
  
  job               JobPost           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  freelancerProfile FreelancerProfile @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)

  @@unique([jobId, freelancerProfileId])
}

model Conversation {
  id            String   @id @default(cuid())
  initiatorId   String
  receiverId    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  initiator User @relation("InitiatedBy", fields: [initiatorId], references: [id])
  receiver  User @relation("ReceivedBy", fields: [receiverId], references: [id])
  messages  Message[]

  @@unique([initiatorId, receiverId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String   @db.Text
  fileUrl        String?
  fileName       String?
  fileType       String?
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())
  
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])
}


enum NotificationType {
  NEW_APPLICATION
  APPLICATION_STATUS_CHANGE
  NEW_MESSAGE
  SYSTEM_ANNOUNCEMENT
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String           @db.Text
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AdminLog {
  id          String   @id @default(cuid())
  adminId     String
  action      String   // e.g. BAN_USER, APPROVE_VERIFICATION, MODERATE_JOB
  targetId    String?  // id of the affected User/Job/FreelancerProfile
  targetType  String?  // "USER", "JOB", "VERIFICATION"
  details     String?  @db.Text
  createdAt   DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@index([adminId])
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model Report {
  id          String       @id @default(cuid())
  reporterId  String
  targetId    String       // ID of the User, Job Post, Profile, etc.
  targetType  String       // e.g., "USER", "JOB", "PROFILE", "MESSAGE"
  reason      String
  details     String?      @db.Text
  status      ReportStatus @default(PENDING)
  adminNotes  String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  reporter    User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([status])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model SupportTicket {
  id          String         @id @default(cuid())
  userId      String
  subject     String
  category    String         // e.g., "Billing", "Technical", "Account"
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    TicketMessage[]

  @@index([userId])
  @@index([status])
}

model TicketMessage {
  id          String        @id @default(cuid())
  ticketId    String
  senderId    String
  message     String        @db.Text
  isAdminReply Boolean      @default(false)
  createdAt   DateTime      @default(now())

  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender      User          @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([senderId])
}

model Review {
  id                  String   @id @default(cuid())
  applicationId       String   @unique
  employerId          String
  freelancerProfileId String
  score               Int      // 1 to 5
  comment             String?  @db.Text
  createdAt           DateTime @default(now())

  application       Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  employer          EmployerProfile   @relation("EmployerReviews", fields: [employerId], references: [id], onDelete: Cascade)
  freelancerProfile FreelancerProfile @relation("FreelancerReviews", fields: [freelancerProfileId], references: [id], onDelete: Cascade)

  @@index([employerId])
  @@index([freelancerProfileId])
}
